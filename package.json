{
  "name": "postcss-spine",
  "version": "0.1.0",
  "description": "PostCSS plugin that splits CSS into a layout-affecting \"spine\" and a paint-only \"complement\", so the spine locks in element dimensions and the rest only repaints.",
  "keywords": [
    "postcss",
    "postcss-plugin",
    "css",
    "layout",
    "reflow",
    "relayout",
    "repaint",
    "paint",
    "performance",
    "critical-css"
  ],
  "author": "Łukasz Sobolewski <lukasz.sobolewski@getresponse.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsobolew/postcss-spine.git"
  },
  "bugs": {
    "url": "https://github.com/lsobolew/postcss-spine/issues"
  },
  "homepage": "https://github.com/lsobolew/postcss-spine#readme",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "postcss": "^8.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
